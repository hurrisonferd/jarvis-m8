"use client";

import { clsx } from "clsx";

// ─── Badge ────────────────────────────────────────────────────────────────────

type BadgeVariant = "amber" | "cyan" | "green" | "red" | "yellow" | "gray";

export function Badge({ children, variant = "gray", className }: {
  children: React.ReactNode;
  variant?: BadgeVariant;
  className?: string;
}) {
  return (
    <span className={clsx(
      "inline-flex items-center px-1.5 py-0.5 rounded text-[9px] font-mono font-bold tracking-wider uppercase",
      `badge-${variant}`, className
    )}>
      {children}
    </span>
  );
}

// ─── Card ─────────────────────────────────────────────────────────────────────

type CardAccent = "amber" | "cyan" | "green" | "red" | "yellow" | "none";

export function Card({ children, accent = "none", className, onClick }: {
  children: React.ReactNode;
  accent?: CardAccent;
  className?: string;
  onClick?: () => void;
}) {
  const accentColors: Record<CardAccent, string> = {
    amber: "border-l-[3px] border-l-j-amber",
    cyan:  "border-l-[3px] border-l-j-cyan",
    green: "border-l-[3px] border-l-j-green",
    red:   "border-l-[3px] border-l-j-red",
    yellow:"border-l-[3px] border-l-j-yellow",
    none:  "",
  };

  return (
    <div
      onClick={onClick}
      className={clsx(
        "bg-j-bg1 border border-j-bd rounded-lg p-3",
        accentColors[accent],
        onClick && "cursor-pointer hover:border-j-muted transition-colors",
        className,
      )}
    >
      {children}
    </div>
  );
}

// ─── ProgressBar ──────────────────────────────────────────────────────────────

export function ProgressBar({ value, status }: { value: number; status: string }) {
  const colorMap: Record<string, string> = {
    green: "bg-j-green",
    yellow: "bg-j-yellow",
    red: "bg-j-red",
    steel: "bg-j-muted",
    purple: "bg-purple-400",
  };

  return (
    <div className="h-[3px] bg-j-bg3 rounded-full overflow-hidden mt-1.5">
      <div
        className={clsx("h-full rounded-full transition-all", colorMap[status] ?? "bg-j-muted")}
        style={{ width: `${value}%` }}
      />
    </div>
  );
}

// ─── SectionLabel ─────────────────────────────────────────────────────────────

export function SectionLabel({ children }: { children: React.ReactNode }) {
  return (
    <div className="text-[9px] font-mono text-j-dim tracking-[0.1em] uppercase mt-4 mb-2 first:mt-0">
      {children}
    </div>
  );
}

// ─── StatCard ─────────────────────────────────────────────────────────────────

export function StatCard({ value, label, color = "text-j-text" }: {
  value: string | number;
  label: string;
  color?: string;
}) {
  return (
    <div className="bg-j-bg2 rounded-lg p-2.5 text-center">
      <div className={clsx("text-xl font-mono font-medium", color)}>{value}</div>
      <div className="text-[9px] font-mono text-j-dim tracking-wider uppercase mt-0.5">{label}</div>
    </div>
  );
}

// ─── Btn ──────────────────────────────────────────────────────────────────────

export function Btn({ children, onClick, primary = false, danger = false, small = false, disabled = false }: {
  children: React.ReactNode;
  onClick?: () => void;
  primary?: boolean;
  danger?: boolean;
  small?: boolean;
  disabled?: boolean;
}) {
  return (
    <button
      onClick={onClick}
      disabled={disabled}
      className={clsx(
        "font-mono rounded border transition-all",
        small ? "text-[9px] px-2 py-0.5" : "text-[10px] px-3 py-1",
        primary
          ? "bg-j-amber border-j-amber text-black font-bold hover:bg-amber-600"
          : danger
          ? "bg-transparent border-j-bd text-j-red hover:border-j-red"
          : "bg-j-bg2 border-j-bd text-j-muted hover:border-j-amber-d hover:text-j-amber",
        disabled && "opacity-40 cursor-not-allowed",
      )}
    >
      {children}
    </button>
  );
}

// ─── Toggle ───────────────────────────────────────────────────────────────────

export function Toggle({ label, checked, onChange }: {
  label: string;
  checked: boolean;
  onChange: () => void;
}) {
  return (
    <div
      onClick={onChange}
      className="flex items-center justify-between bg-j-bg2 border border-j-bd rounded-md px-3 py-2 cursor-pointer hover:border-j-amber-d transition-colors mb-1.5"
    >
      <span className="text-[11px] font-mono text-j-text">{label}</span>
      <div className={clsx(
        "w-[26px] h-[13px] rounded-full relative transition-colors",
        checked ? "bg-j-amber" : "bg-j-bg3"
      )}>
        <div className={clsx(
          "absolute w-[9px] h-[9px] rounded-full top-[2px] transition-all",
          checked ? "left-[15px] bg-black" : "left-[2px] bg-j-muted"
        )} />
      </div>
    </div>
  );
}
